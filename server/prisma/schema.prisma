// ─── Production Bible App — Prisma Schema ───
// Spec: Production_App_Specification_v1.0.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum AuthProvider {
  GOOGLE
  APPLE
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum Role {
  DIRECTOR
  AD
  DEPARTMENT_HEAD
  TEAM_MEMBER
}

enum ObjectiveStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum NotificationType {
  MENTION
  STATUS_CHANGE
  COMMENT
  INVITATION
}

// ─── User ───

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  displayName  String?
  avatarUrl    String?
  authProvider AuthProvider
  isOnboarded  Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships            ProjectMember[]
  createdProjects        Project[]              @relation("ProjectCreator")
  createdObjectives      Objective[]            @relation("ObjectiveCreator")
  objectiveCollaborations ObjectiveCollaborator[]
  decisions              Decision[]
  comments               Comment[]
  commentReactions       CommentReaction[]
  commentMentions        CommentMention[]
  notifications          Notification[]
  createdInvites         ProjectInvite[]

  @@map("users")
}

// ─── Project ───

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  archivedAt  DateTime?

  createdBy   User          @relation("ProjectCreator", fields: [createdById], references: [id])
  members     ProjectMember[]
  departments Department[]
  objectives  Objective[]
  templates   Template[]    @relation("ProjectTemplates")
  invites     ProjectInvite[]

  @@map("projects")
}

// ─── Project Member ───

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  roles     Role[]
  joinedAt  DateTime @default(now())

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  departments MemberDepartment[]

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── Member ↔ Department (join table) ───

model MemberDepartment {
  memberId     String
  departmentId String

  member     ProjectMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  department Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([memberId, departmentId])
  @@map("member_departments")
}

// ─── Department ───

model Department {
  id        String  @id @default(uuid())
  projectId String
  name      String
  icon      String?
  color     String?
  isCustom  Boolean @default(false)
  order     Int     @default(0)

  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members              MemberDepartment[]
  primaryObjectives    Objective[]            @relation("PrimaryDepartment")
  sharedObjectives     ObjectiveDepartment[]

  @@map("departments")
}

// ─── Objective ───

model Objective {
  id                String          @id @default(uuid())
  projectId         String
  primaryDeptId     String
  templateId        String?
  title             String
  description       String?
  status            ObjectiveStatus @default(NOT_STARTED)
  deadline          DateTime?
  phase             String?
  sceneOrLocation   String?
  whatIsNormallyDone String?
  directorsVision   String?
  createdById       String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  project        Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  primaryDept    Department            @relation("PrimaryDepartment", fields: [primaryDeptId], references: [id])
  template       Template?             @relation(fields: [templateId], references: [id])
  createdBy      User                  @relation("ObjectiveCreator", fields: [createdById], references: [id])
  departments    ObjectiveDepartment[]
  collaborators  ObjectiveCollaborator[]
  decisions      Decision[]
  links          Link[]
  comments       Comment[]

  @@index([projectId, status])
  @@index([primaryDeptId])
  @@map("objectives")
}

// ─── Objective ↔ Department (cross-dept sharing) ───

model ObjectiveDepartment {
  objectiveId  String
  departmentId String

  objective  Objective  @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([objectiveId, departmentId])
  @@map("objective_departments")
}

// ─── Objective Collaborator ───

model ObjectiveCollaborator {
  id          String   @id @default(uuid())
  objectiveId String
  userId      String
  isActive    Boolean  @default(true)
  joinedAt    DateTime @default(now())

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([objectiveId, userId])
  @@map("objective_collaborators")
}

// ─── Decision ───

model Decision {
  id          String   @id @default(uuid())
  objectiveId String
  content     String
  createdById String
  createdAt   DateTime @default(now())

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id])

  @@index([objectiveId])
  @@map("decisions")
}

// ─── Link ───

model Link {
  id          String   @id @default(uuid())
  objectiveId String
  url         String
  description String?
  authorName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId])
  @@map("links")
}

// ─── Comment ───

model Comment {
  id          String   @id @default(uuid())
  objectiveId String
  parentId    String?
  content     String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  objective Objective        @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  parent    Comment?         @relation("CommentThread", fields: [parentId], references: [id])
  replies   Comment[]        @relation("CommentThread")
  createdBy User             @relation(fields: [createdById], references: [id])
  reactions CommentReaction[]
  mentions  CommentMention[]

  @@index([objectiveId])
  @@index([parentId])
  @@map("comments")
}

// ─── Comment Reaction ───

model CommentReaction {
  id        String @id @default(uuid())
  commentId String
  userId    String
  emoji     String

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@map("comment_reactions")
}

// ─── Comment Mention ───

model CommentMention {
  id              String @id @default(uuid())
  commentId       String
  mentionedUserId String

  comment       Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser User    @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@index([mentionedUserId])
  @@map("comment_mentions")
}

// ─── Template ───

model Template {
  id            String   @id @default(uuid())
  projectId     String?
  name          String
  objectiveType String
  content       String
  checklist     Json?
  isSystem      Boolean  @default(false)
  createdAt     DateTime @default(now())

  project    Project?    @relation("ProjectTemplates", fields: [projectId], references: [id], onDelete: Cascade)
  objectives Objective[]

  @@map("templates")
}

// ─── Notification ───

model Notification {
  id            String           @id @default(uuid())
  userId        String
  type          NotificationType
  referenceId   String
  referenceType String
  read          Boolean          @default(false)
  createdAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ─── Project Invite ───

model ProjectInvite {
  id          String    @id @default(uuid())
  projectId   String
  token       String    @unique
  email       String?
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([token])
  @@map("project_invites")
}
